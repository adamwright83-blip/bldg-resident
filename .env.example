# Frontend (Vite): API base URL. Required for app.bldg.chat so the client calls api.bldg.chat.
# In Vercel: set Environment Variable VITE_API_URL = https://api.bldg.chat (for Production).
VITE_API_URL=https://api.bldg.chat

# Resident safety switch. Defaults to safe test mode unless explicitly disabled.
# In test mode, the app can save a fake card and create local service requests
# without calling Stripe, admin intake, ops intake, or owner notifications.
RESIDENT_APP_TEST_MODE=true
VITE_RESIDENT_APP_TEST_MODE=true

# Optional transactional receipt delivery. Orders still succeed when omitted.
RESEND_API_KEY=
RESEND_FROM_EMAIL=HELD <receipts@bldg.chat>
RESEND_REPLY_TO_EMAIL=support@bldg.chat
